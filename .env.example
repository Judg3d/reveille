# Required. Dockhand API token passed into the Reveille container.
# Do not commit a real token.
DOCKHAND_API_TOKEN=dh_replace_me

# Host port exposed by Compose. The container always listens on 8080.
# Change this if another service already uses port 8080 on the Docker host.
REVEILLE_PORT=8080

# Image repository used by compose.yml. Leave this as-is unless you publish the
# image to a different registry or namespace.
REVEILLE_IMAGE=ghcr.io/your-org/reveille

# Image tag used by compose.yml. Common values are "latest", a release version
# like "v0.1.0", or a commit SHA tag if your registry publishes those.
REVEILLE_TAG=latest
