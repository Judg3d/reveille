# Optional. Leave blank when Dockhand authentication is disabled.
# If your Dockhand deployment requires API auth, set the token here or through
# your deployment secret store. Do not commit a real token.
DOCKHAND_API_TOKEN=

# Optional direct host publishing for deployments that do not route Reveille
# through Traefik. Keep REVEILLE_BIND_HOST narrow; use 127.0.0.1 for local-only
# access, a specific LAN/VPN host IP for restricted remote access, or 0.0.0.0
# only when intentionally exposing Reveille on every host interface.
REVEILLE_BIND_HOST=127.0.0.1
REVEILLE_PORT=8080

# Image tag used by compose.yml. Common values are "latest", a release version
# like "v0.1.0", or a commit SHA tag if your registry publishes those.
REVEILLE_TAG=latest
