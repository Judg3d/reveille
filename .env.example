# Optional. Leave blank when Dockhand authentication is disabled.
# Compose loads this file with env_file and passes DOCKHAND_API_TOKEN into the
# Reveille container. If your Dockhand deployment requires API auth, set the
# token here or through your deployment secret store. Do not commit a real token.
DOCKHAND_API_TOKEN=

# Image tag used by compose.yml. Common values are "latest", a release version
# like "v0.1.0", or a commit SHA tag if your registry publishes those.
REVEILLE_TAG=latest
